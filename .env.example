# SecProbe Environment Configuration
# Copy to .env and fill in your values

# ─────────────────────────────────────────────
# FREE AI PROVIDERS (pick one or both)
# ─────────────────────────────────────────────

# Option 1: Google Gemini Flash (FREE)
# Get your free key in 30 seconds: https://aistudio.google.com/app/apikey
# Free limits: 15 req/min, 1,500 req/day, 1M tokens/day
# GEMINI_API_KEY=your_gemini_key_here

# Option 2: Groq LLaMA 3 (FREE, ultra fast)
# Get your free key in 30 seconds: https://console.groq.com/keys
# Free limits: 30 req/min, 14,400 req/day
# GROQ_API_KEY=your_groq_key_here

# Option 3: No key at all → Offline engine activates automatically
# Just run: secprobe example.com --ai

# ─────────────────────────────────────────────
# API SERVER SETTINGS
# ─────────────────────────────────────────────
SECPROBE_HOST=0.0.0.0
SECPROBE_PORT=5000
SECPROBE_DEBUG=false

# Optional: protect your REST API with a key
# SECPROBE_API_KEY=your_secret_api_key
